<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Fix case sensitivity: redirect /Assets to /assets (Linux servers are case-sensitive)
    RewriteRule ^Assets/(.*)$ assets/$1 [R=301,L]
    
    # Don't rewrite if file or directory exists
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Rewrite to index.php using query string format (works with both mod_php and FastCGI)
    RewriteRule ^(.*)$ index.php?/$1 [QSA,L]
</IfModule> 